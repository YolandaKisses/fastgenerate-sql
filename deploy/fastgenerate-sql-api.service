[Unit]
Description=FastGenerate SQL 后端服务
After=network.target

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/opt/fastgenerate-sql/app/api
EnvironmentFile=/etc/fastgenerate-sql/fastgenerate-sql.env
ExecStart=/opt/fastgenerate-sql/app/api/venv/bin/uvicorn app.main:app --host 127.0.0.1 --port 8000
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
